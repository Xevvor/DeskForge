<Window x:Class="DeskForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeskForge"
        xmlns:vm="clr-namespace:DeskForge.ViewModels"
        xmlns:controls="clr-namespace:DeskForge.Controls"
        xmlns:services="clr-namespace:DeskForge.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="DeskForge" Height="700" Width="600" MinHeight="560" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===================== Custom title bar ===================== -->
            <Grid Grid.Row="0" Background="{StaticResource SidebarBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="13" Margin="0,0,6,0"/>
                    <TextBlock Text="DeskForge" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Style="{StaticResource TitleBarButtonStyle}" Click="MinimizeButton_Click"
                            AutomationProperties.Name="Minimize">
                        <Rectangle Width="10" Height="1" Fill="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButtonStyle}" Click="MaximizeButton_Click"
                            AutomationProperties.Name="Maximize">
                        <Grid Width="10" Height="10">
                            <Rectangle x:Name="MaximizeIcon" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"/>
                            <Grid x:Name="RestoreIcon" Visibility="Collapsed">
                                <Rectangle Width="7" Height="7" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"
                                           HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                <Rectangle Width="7" Height="7" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"
                                           Fill="{StaticResource SidebarBrush}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Grid>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource TitleBarCloseButtonStyle}" Click="CloseButton_Click"
                            AutomationProperties.Name="Close">
                        <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.2"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===================== Body: sidebar + content ===================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- Logo / app name -->
                        <StackPanel DockPanel.Dock="Top" Margin="20,20,20,18">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="22" Margin="0,0,8,0"/>
                                <TextBlock Text="DeskForge" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Your Windows command center" FontSize="11" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="30,4,0,0"/>
                        </StackPanel>

                        <!-- Footer -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="20,12,20,18">
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="DeskForge Prototype" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{x:Static services:AppInfo.Version}" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Navigation -->
                        <ListBox ItemsSource="{Binding NavItems}"
                                 SelectedItem="{Binding SelectedNavItem}"
                                 Style="{StaticResource NavListBoxStyle}"
                                 ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" Width="24"/>
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Main content -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Page header -->
                    <Border Grid.Row="0" Padding="24,18,24,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SelectedNavItem.Icon}" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding SelectedNavItem.Title}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Page content: AnimatedContentControl fades + slides in whenever the page changes. -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24,20,24,20">
                        <controls:AnimatedContentControl Content="{Binding CurrentViewModel}"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
