<Application x:Class="DeskForge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DeskForge"
             xmlns:vm="clr-namespace:DeskForge.ViewModels"
             xmlns:views="clr-namespace:DeskForge.Views"
             xmlns:conv="clr-namespace:DeskForge.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:EnumEqualsToVisibilityConverter x:Key="EnumVis"/>
            <conv:ZeroCountToVisibilityConverter x:Key="ZeroCountVis"/>
            <conv:InverseBooleanConverter x:Key="InverseBool"/>

            <!-- Maps each page view model to its view, so ContentControl swaps pages automatically. -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LauncherViewModel}">
                <views:LauncherView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FileCleanerViewModel}">
                <views:FileCleanerView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FileOrganizerViewModel}">
                <views:FileOrganizerView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:QuickToolsViewModel}">
                <views:QuickToolsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
