<UserControl x:Class="DeskForge.Views.FileCleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DeskForge.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:FileCleanerViewModel}"
             d:DesignWidth="380">
    <StackPanel>
        <TextBlock Text="File Cleaner" FontSize="20" FontWeight="Bold"/>
        <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,18"
                   Text="Find large files, old downloads, duplicates, and temp files. Scanning is read-only."/>

        <Border Style="{StaticResource CardStyle}" Padding="16">
            <StackPanel>
                <TextBox Text="{Binding SelectedFolder}" IsReadOnly="True" Margin="0,0,0,10"
                          VerticalContentAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Choose Folder" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ChooseFolderCommand}" Margin="0,0,10,0"/>
                    <Button Content="🔍  Scan Folder" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ScanFolderCommand}"/>
                </StackPanel>
                <ProgressBar Style="{StaticResource LoadingBarStyle}" Margin="0,14,0,0"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0" Padding="0" MinHeight="120">
            <StackPanel>
                <DataGrid ItemsSource="{Binding Results}" Margin="6" MaxHeight="380">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="34"/>
                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="2*"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="*"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding FileType}" Width="*"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Category}" Width="*"/>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="3*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Button Content="🗑  Clean Selected" Style="{StaticResource DangerButtonStyle}"
                            HorizontalAlignment="Left" Command="{Binding CleanSelectedCommand}"/>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
