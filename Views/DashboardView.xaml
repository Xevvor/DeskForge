<UserControl x:Class="DeskForge.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DeskForge.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             d:DesignWidth="380">
    <StackPanel>
        <TextBlock Text="Welcome to DeskForge" FontSize="24" FontWeight="Bold" TextWrapping="Wrap"/>
        <TextBlock Text="Your all-in-one Windows toolbox — clean, organize, and launch, all from one place."
                   FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,22"/>

        <!-- Stat cards -->
        <UniformGrid Columns="2" Margin="-6,0,-6,0">
            <Border Style="{StaticResource CardStyle}" Margin="6" Padding="16">
                <StackPanel>
                    <TextBlock Text="🧩" FontSize="20"/>
                    <TextBlock Text="{Binding Stats.ToolsAvailable}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="Tools Available" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="6" Padding="16">
                <StackPanel>
                    <TextBlock Text="📄" FontSize="20"/>
                    <TextBlock Text="{Binding Stats.FilesScanned}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="Files Scanned" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="6" Padding="16">
                <StackPanel>
                    <TextBlock Text="🎮" FontSize="20"/>
                    <TextBlock Text="{Binding Stats.ShortcutsCount}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="Shortcuts" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="6" Padding="16">
                <StackPanel>
                    <TextBlock Text="💾" FontSize="20"/>
                    <TextBlock Text="{Binding Stats.StorageSavedDisplay}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="Storage Saved" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Quick actions -->
        <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold" Margin="0,26,0,12"/>
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Button Content="🧹  Clean Downloads" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CleanDownloadsCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
                <Button Content="🎮  Open Launcher" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding OpenLauncherCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
                <Button Content="🔍  Scan Files" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ScanFilesCommand}" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- About card -->
        <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="About this prototype" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           Text="DeskForge bundles a Launcher, File Cleaner, File Organizer, and Quick Tools into one dashboard. Scanning reads real files from disk; cleaning and organizing are preview/simulated so nothing on your PC is changed without your say-so."/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
