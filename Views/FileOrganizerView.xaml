<UserControl x:Class="DeskForge.Views.FileOrganizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DeskForge.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:FileOrganizerViewModel}"
             d:DesignWidth="380">
    <StackPanel>
        <TextBlock Text="File Organizer" FontSize="20" FontWeight="Bold"/>
        <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,18"
                   Text="Preview how DeskForge would sort a folder by file type. Nothing moves until you say so."/>

        <!-- Rules -->
        <TextBlock Text="Rules" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <Border Style="{StaticResource CardStyle}" Padding="6" Margin="0,0,0,16">
            <ItemsControl ItemsSource="{Binding Rules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap">
                                        <Run Text="{Binding SourceType, Mode=OneWay}"/>
                                        <Run Text=" → "/>
                                        <Run Text="{Binding TargetFolder, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Extensions}" FontSize="10" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Folder + actions -->
        <Border Style="{StaticResource CardStyle}" Padding="16">
            <StackPanel>
                <TextBox Text="{Binding SelectedFolder}" IsReadOnly="True" Margin="0,0,0,10"
                          VerticalContentAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Choose Folder" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ChooseFolderCommand}" Margin="0,0,10,0"/>
                    <Button Content="👁  Organize Preview" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding OrganizePreviewCommand}"/>
                </StackPanel>
                <ProgressBar Style="{StaticResource LoadingBarStyle}" Margin="0,14,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Preview results -->
        <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0" Padding="0" MinHeight="120">
            <DataGrid ItemsSource="{Binding PreviewResults}" Margin="6" MaxHeight="380">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="2*"/>
                    <DataGridTextColumn Header="Rule" Binding="{Binding RuleApplied}" Width="1.5*"/>
                    <DataGridTextColumn Header="Would Move To" Binding="{Binding DestinationFolder}" Width="3*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </StackPanel>
</UserControl>
